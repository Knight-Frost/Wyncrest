# Wyncrest frontend environment (Vite). Copy to .env.local to override defaults.

# Base URL the SPA uses for API calls.
# Leave unset in development, the Vite dev server proxies "/api" to the backend.
# In production, set this to your deployed API origin, e.g. https://api.wyncrest.app/api
# VITE_API_BASE_URL=/api

# Backend origin the dev proxy targets (development only).
# Defaults to http://localhost:8000 (the `php artisan serve` default).
# VITE_API_PROXY=http://localhost:8000

# Stripe publishable key — enables the in-app card checkout on the tenant
# Payments page. Must be paired with STRIPE_SECRET_KEY on the API. When unset
# (e.g. the keyless demo), Payments shows an honest "online payments not
# enabled here" state instead of a checkout that can only fail.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
