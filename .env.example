# =============================================================================
# WYNCREST ENVIRONMENT CONFIGURATION
# =============================================================================
# SECURITY WARNING: Never commit .env to version control!
# Copy this file to .env and fill in your values.
# =============================================================================

APP_NAME=Wyncrest
APP_ENV=local
APP_KEY=
# SECURITY: Set to false in production to prevent information leakage
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@wyncrest.app"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ADMIN_ADDRESS=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# BRANDING
# =============================================================================
# Override any of these to rename the product — do NOT hand-edit brand strings
# across source files. Backend reads BRAND_* via config/brand.php; frontend
# reads VITE_* via src/config/brand.ts; index.html is injected by the Vite
# html-brand-vars plugin defined in vite.config.js.
#
# BRAND_DISPLAY_NAME=Wyncrest
# BRAND_SHORT_NAME=Wyncrest
# BRAND_LEGAL_NAME=Wyncrest
# BRAND_SUPPORT_NAME=Wyncrest Support
# BRAND_DESCRIPTOR=Property Platform
# BRAND_TAGLINE=A higher standard for modern renting.
# BRAND_SECONDARY_TAGLINE=Every lease, payment, and record in trusted order.
# MAIL_ADMIN_ADDRESS=admin@wyncrest.app
#
# Frontend brand env vars (Vite — must be prefixed VITE_):
# VITE_BRAND_SHORT_NAME=Wyncrest
# VITE_BRAND_INITIAL=W
# VITE_BRAND_DESCRIPTOR=Property Platform
# VITE_BRAND_TAGLINE=A higher standard for modern renting.
# VITE_BRAND_SECONDARY_TAGLINE=Every lease, payment, and record in trusted order.
# VITE_BRAND_AUTH_HEADLINE=A higher standard for modern renting.
# VITE_BRAND_AUTH_SUBHEADLINE=Manage verified listings, leases, documents, payments, and property records in one trusted place.
# VITE_SUPPORT_NAME=Wyncrest Support
# VITE_BRAND_LEGAL_NAME=Wyncrest

# Database Seeding
# ----------------
# The project prefers WYNCREST_* env names; the legacy NEXUS_* names are still
# read as fallbacks, so either works. Prefer WYNCREST_* going forward.
#
# Seed mode. Leave blank to auto-resolve (production APP_ENV => production,
# otherwise development). Override explicitly with 'development' or 'production'.
#   WYNCREST_SEED_MODE=development php artisan migrate:fresh --seed
#   WYNCREST_SEED_MODE=production  php artisan db:seed     # safe baseline only
# WYNCREST_SEED_MODE=
#
# Development demo data knobs (LOCAL ONLY — never used in production mode):
# WYNCREST_DEMO_PASSWORD=password          # shared password for every demo account
# WYNCREST_DEMO_DOMAIN=wyncrest.test       # reserved test domain for demo emails
# WYNCREST_DEMO_TENANTS=5                   # expected demo tenant count (4 good + 1 owing)
# WYNCREST_DEMO_LANDLORDS=5                 # expected demo landlord count
# WYNCREST_DEMO_CURRENCY=GHS
#
# Production bootstrap admin (OPTIONAL). If all three are set, the ProductionSeeder
# firstOrCreate()s one admin; otherwise it is SKIPPED with a warning. NEVER commit
# real values — set these in the server env only. (./dev.sh --prod sets safe local
# defaults so the production preview always has one admin to log in.)
# WYNCREST_BOOTSTRAP_ADMIN_EMAIL=
# WYNCREST_BOOTSTRAP_ADMIN_NAME=
# WYNCREST_BOOTSTRAP_ADMIN_PASSWORD=
#
# Safety latch: must be true to allow the development seeder to run while
# APP_ENV=production (prevents accidental demo-data poisoning). Default false.
# WYNCREST_ALLOW_DEV_SEED_IN_PROD=false

# Stripe Configuration
# Get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Twilio SMS Configuration
# Get your credentials from https://console.twilio.com
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# OpenWeatherMap — Tenant dashboard weather chip
# Get a free key at https://openweathermap.org/api (free tier is sufficient)
# Leave blank to disable the weather widget gracefully.
OPENWEATHER_API_KEY=
WEATHER_DEFAULT_CITY=Accra

# Sanctum Token Expiration (minutes) - 1440 = 24 hours
# SECURITY: Consider shorter expiration for high-security deployments
SANCTUM_TOKEN_EXPIRATION=1440

# =============================================================================
# MEDIA STORAGE
# =============================================================================
# Set these to 's3' (or your preferred cloud driver) in production.
# Swapping the disk is all that's needed — no code changes required.
# MEDIA_DISK_PUBLIC=public
# MEDIA_DISK_PRIVATE=local
# MEDIA_MAX_SIZE_KB=8192
# MEDIA_ALLOWED_MIMES=jpg,jpeg,png,webp

# Frontend URL (for CORS and SPA deep-links such as password-reset emails)
FRONTEND_URL=http://localhost:5173
APP_FRONTEND_URL=http://localhost:5173

# Google OAuth (Socialite) — leave blank to disable Google sign-in gracefully.
# Register an OAuth 2.0 client at https://console.cloud.google.com/
# Authorized redirect URI must match GOOGLE_REDIRECT_URI exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# CORS Allowed Origins (comma-separated)
# Add your production frontend domain here
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Sanctum stateful domains (comma-separated)
# Add your production frontend domain here
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:5173,127.0.0.1,127.0.0.1:8000

# =============================================================================
# PRODUCTION SECURITY CHECKLIST
# =============================================================================
# Before deploying to production, ensure:
# [ ] APP_ENV=production
# [ ] APP_DEBUG=false
# [ ] APP_KEY is set (run: php artisan key:generate)
# [ ] APP_URL is set to your production domain (https://)
# [ ] FRONTEND_URL is set to your production frontend domain
# [ ] SANCTUM_STATEFUL_DOMAINS includes your production frontend domain
# [ ] SESSION_SECURE_COOKIE=true (for HTTPS)
# [ ] SESSION_SAME_SITE=lax (or strict for enhanced security)
# [ ] All API keys and secrets are set (Stripe, Twilio)
# [ ] Database credentials are secure
# [ ] HTTPS is enforced at server level
# [ ] Rate limiting is properly configured
# =============================================================================
